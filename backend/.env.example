# Copy to .env and fill in real values. Never commit .env.
# Place .env in backend/src/ (next to config.py) or in the directory set by PLANT_SETTINGS_DIR.
# See project README for full configuration and Tailscale setup.

# --- InfluxDB (required for trends + sensor logging) ---
INFLUX_URL=http://YOUR_INFLUX_HOST:8086
INFLUX_TOKEN=
INFLUX_ORG=HomeSensors
INFLUX_BUCKET=plantMonitor

# --- API server (defaults: bind 0.0.0.0:5000 for Tailscale/LAN) ---
# PLANT_API_HOST=0.0.0.0
# PLANT_API_PORT=5000

# --- CORS: comma-separated origins that may call the API (add Tailscale URL for remote UI) ---
# Example for LAN/Tailscale: add your Pi or dev machine origin
# PLANT_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://192.168.1.10:5173

# --- Pi Zero / low-resource: set to 1 for verbose debug logging (default: minimal) ---
# PLANT_DEBUG=1
